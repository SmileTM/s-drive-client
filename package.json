{
  "name": "webdev-client-pro",
  "version": "1.0.0",
  "description": "Local Cloud Drive Manager (Web + WebDAV)",
  "main": "electron/main.js",
  "scripts": {
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"npm run server --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.webdev.client",
    "productName": "WebDev Drive",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"]
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "asar": true
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "wait-on": "^7.2.0",
    "webdav": "^5.8.0",
    "webdav-server": "^2.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "kill-port": "^2.0.1"
  }
}
